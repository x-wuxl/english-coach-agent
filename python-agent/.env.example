# LLM Configuration
# Default model (used when task-specific model is not set)
LLM_DEFAULT_MODEL=deepseek/deepseek-chat
LLM_API_KEY=your-api-key-here
LLM_API_BASE=

# Per-task model overrides (optional, falls back to LLM_DEFAULT_MODEL)
LLM_COACH_MODEL=
LLM_EXPLANATION_MODEL=

# LiteLLM settings
LLM_TIMEOUT=30
LLM_MAX_RETRIES=2
