# LLM Configuration
LLM_DEFAULT_MODEL=deepseek/deepseek-chat
LLM_API_KEY=your-api-key-here
LLM_API_BASE=

# Per-task model overrides (optional)
LLM_COACH_MODEL=
LLM_EXPLANATION_MODEL=
LLM_REFLECTION_MODEL=

# Fallback model (used when primary fails)
LLM_FALLBACK_MODEL=

# LiteLLM settings
LLM_TIMEOUT=30
LLM_MAX_RETRIES=2

# Tracing
TRACING_ENABLED=true

# Harness
HARNESS_RECORD_DIR=harness_records
